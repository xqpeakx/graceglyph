{
  "name": "zenterm",
  "version": "0.0.1",
  "description": "Cross-platform retained-mode TUI framework for Node.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-runtime.d.ts",
      "import": "./dist/jsx-runtime.js"
    },
    "./jsx-dev-runtime": {
      "types": "./dist/jsx-dev-runtime.d.ts",
      "import": "./dist/jsx-dev-runtime.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -p tsconfig.json --watch",
    "clean": "rm -rf dist",
    "dev:hello": "node --watch --experimental-specifier-resolution=node --loader ts-node/esm examples/hello.tsx",
    "dev:todo": "node --watch --experimental-specifier-resolution=node --loader ts-node/esm examples/todo.tsx",
    "dev:explorer": "node --watch --experimental-specifier-resolution=node --loader ts-node/esm examples/explorer.tsx",
    "example:hello": "node --experimental-specifier-resolution=node --loader ts-node/esm examples/hello.tsx",
    "example:form": "node --experimental-specifier-resolution=node --loader ts-node/esm examples/form.tsx",
    "example:showcase": "node --experimental-specifier-resolution=node --loader ts-node/esm examples/showcase.tsx",
    "example:todo": "node --experimental-specifier-resolution=node --loader ts-node/esm examples/todo.tsx",
    "example:explorer": "node --experimental-specifier-resolution=node --loader ts-node/esm examples/explorer.tsx",
    "test": "node --test --loader ts-node/esm test/*.test.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "tui",
    "terminal",
    "ui",
    "ansi",
    "console",
    "cli"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
