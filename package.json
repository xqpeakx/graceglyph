{
  "name": "graceglyph",
  "version": "0.0.1",
  "description": "Terminal UI toolkit for TypeScript.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "create-graceglyph": "./dist/create.js",
    "graceglyph-create": "./dist/create.js",
    "gg-logs": "./dist/apps/gg-logs/index.js",
    "gg-monitor": "./dist/apps/gg-monitor/index.js",
    "gg-files": "./dist/apps/gg-files/index.js",
    "gg-git": "./dist/apps/gg-git/index.js",
    "gg-chat": "./dist/apps/gg-chat/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-runtime.d.ts",
      "import": "./dist/jsx-runtime.js"
    },
    "./jsx-dev-runtime": {
      "types": "./dist/jsx-dev-runtime.d.ts",
      "import": "./dist/jsx-dev-runtime.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -p tsconfig.json --watch",
    "clean": "rm -rf dist",
    "dev:showcase": "node --watch --experimental-specifier-resolution=node --loader ts-node/esm examples/dashboard-shell.tsx",
    "dev:monitor": "node --watch --experimental-specifier-resolution=node --loader ts-node/esm examples/dashboard-shell.tsx system-monitor",
    "dev:logs": "node --watch --experimental-specifier-resolution=node --loader ts-node/esm examples/dashboard-shell.tsx log-viewer",
    "dev:git": "node --watch --experimental-specifier-resolution=node --loader ts-node/esm examples/dashboard-shell.tsx git-dashboard",
    "dev:api": "node --watch --experimental-specifier-resolution=node --loader ts-node/esm examples/dashboard-shell.tsx api-explorer",
    "dev:files": "node --watch --experimental-specifier-resolution=node --loader ts-node/esm examples/dashboard-shell.tsx file-manager",
    "dev:hello": "node --watch --experimental-specifier-resolution=node --loader ts-node/esm examples/dashboard-shell.tsx hello",
    "dev:form": "node --watch --experimental-specifier-resolution=node --loader ts-node/esm examples/dashboard-shell.tsx form",
    "dev:todo": "node --watch --experimental-specifier-resolution=node --loader ts-node/esm examples/dashboard-shell.tsx todo",
    "dev:explorer": "node --watch --experimental-specifier-resolution=node --loader ts-node/esm examples/dashboard-shell.tsx file-manager",
    "dev:components": "node --watch --experimental-specifier-resolution=node --loader ts-node/esm examples/dashboard-shell.tsx components",
    "dev:tarnished": "node --watch --experimental-specifier-resolution=node --loader ts-node/esm examples/tarnished-splash.tsx",
    "app:gg-logs": "node --experimental-specifier-resolution=node --loader ts-node/esm apps/gg-logs/index.tsx",
    "app:gg-monitor": "node --experimental-specifier-resolution=node --loader ts-node/esm apps/gg-monitor/index.tsx",
    "app:gg-files": "node --experimental-specifier-resolution=node --loader ts-node/esm apps/gg-files/index.tsx",
    "app:gg-git": "node --experimental-specifier-resolution=node --loader ts-node/esm apps/gg-git/index.tsx",
    "app:gg-chat": "node --experimental-specifier-resolution=node --loader ts-node/esm apps/gg-chat/index.tsx",
    "example:showcase": "node --experimental-specifier-resolution=node --loader ts-node/esm examples/dashboard-shell.tsx",
    "example:monitor": "node --experimental-specifier-resolution=node --loader ts-node/esm examples/dashboard-shell.tsx system-monitor",
    "example:logs": "node --experimental-specifier-resolution=node --loader ts-node/esm examples/dashboard-shell.tsx log-viewer",
    "example:git": "node --experimental-specifier-resolution=node --loader ts-node/esm examples/dashboard-shell.tsx git-dashboard",
    "example:api": "node --experimental-specifier-resolution=node --loader ts-node/esm examples/dashboard-shell.tsx api-explorer",
    "example:files": "node --experimental-specifier-resolution=node --loader ts-node/esm examples/dashboard-shell.tsx file-manager",
    "example:shell": "node --experimental-specifier-resolution=node --loader ts-node/esm examples/dashboard-shell.tsx",
    "example:hello": "node --experimental-specifier-resolution=node --loader ts-node/esm examples/dashboard-shell.tsx hello",
    "example:form": "node --experimental-specifier-resolution=node --loader ts-node/esm examples/dashboard-shell.tsx form",
    "example:todo": "node --experimental-specifier-resolution=node --loader ts-node/esm examples/dashboard-shell.tsx todo",
    "example:explorer": "node --experimental-specifier-resolution=node --loader ts-node/esm examples/dashboard-shell.tsx file-manager",
    "example:components": "node --experimental-specifier-resolution=node --loader ts-node/esm examples/dashboard-shell.tsx components",
    "example:tarnished": "node --experimental-specifier-resolution=node --loader ts-node/esm examples/tarnished-splash.tsx",
    "test": "node --test --loader ts-node/esm test/*.test.ts",
    "test:coverage": "c8 --reporter=text --reporter=lcov --check-coverage --lines 80 --branches 75 node --test --loader ts-node/esm test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "bench": "node --experimental-specifier-resolution=node --loader ts-node/esm bench/run.ts",
    "bench:prof": "node --prof --experimental-specifier-resolution=node --loader ts-node/esm bench/run.ts",
    "bench:check": "node --experimental-specifier-resolution=node --loader ts-node/esm bench/run.ts --json | node scripts/check-bench-thresholds.mjs -",
    "bench:drift": "node --experimental-specifier-resolution=node --loader ts-node/esm bench/run.ts --json | node scripts/check-bench-drift.mjs - bench/baseline.json",
    "bench:compare": "node --experimental-specifier-resolution=node --loader ts-node/esm bench/run.ts --json | node scripts/bench-compare.mjs -",
    "docs:dev": "vitepress dev docs/site",
    "docs:build": "vitepress build docs/site",
    "docs:preview": "vitepress preview docs/site"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "tui",
    "terminal",
    "ui",
    "ansi",
    "console",
    "cli"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "c8": "^11.0.0",
    "eslint": "^9.10.0",
    "fast-check": "^4.7.0",
    "prettier": "^3.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.6.0",
    "vitepress": "^1.6.4"
  }
}
